# ===================================================================
# Sláinte Finance V2 - Environment Configuration
# ===================================================================
#
# SECURITY NOTE: This .env file should NOT contain your Anthropic API key!
# Users enter their API key during the onboarding process in the app.
# This keeps API keys secure and allows each practice to use their own key.
#
# Only for development/testing: You can add ANTHROPIC_API_KEY here,
# but it will only be used in development mode, not production.
# ===================================================================

# JWT Secret for partner authentication (REQUIRED)
# Generate a secure random string with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-key-here

# Partner Password for mobile login (REQUIRED)
# Partners use this password to log in to the mobile PWA
PARTNER_PASSWORD=slainte2024

# API URL for mobile PWA (REQUIRED)
# Development: http://localhost:3001
# Production: Your Cloudflare Tunnel URL (e.g., https://yourpractice.slainte.com)
VITE_API_URL=http://localhost:3001

# ===================================================================
# OPTIONAL: Development-only API key
# ===================================================================
# Uncomment the line below ONLY for development/testing.
# In production, users will enter their key during onboarding.
# ANTHROPIC_API_KEY=your-api-key-here
